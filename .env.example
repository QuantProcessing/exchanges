# =============================================================================
# Exchanges — Environment Variables for Integration Tests
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!

# --- Binance ---
EXCHANGES_BINANCE_API_KEY=
EXCHANGES_BINANCE_SECRET_KEY=

# --- OKX ---
EXCHANGES_OKX_API_KEY=
EXCHANGES_OKX_SECRET_KEY=
EXCHANGES_OKX_PASSPHRASE=

# --- Aster ---
EXCHANGES_ASTER_API_KEY=
EXCHANGES_ASTER_SECRET_KEY=

# --- Nado ---
EXCHANGES_NADO_PRIVATE_KEY=
EXCHANGES_NADO_SUB_ACCOUNT_NAME=

# --- Lighter ---
EXCHANGES_LIGHTER_PRIVATE_KEY=
EXCHANGES_LIGHTER_ACCOUNT_INDEX=
EXCHANGES_LIGHTER_KEY_INDEX=
EXCHANGES_LIGHTER_RO_TOKEN=

# --- Hyperliquid ---
EXCHANGES_HYPERLIQUID_PRIVATE_KEY=
EXCHANGES_HYPERLIQUID_ACCOUNT_ADDR=

# --- StandX ---
EXCHANGES_STANDX_PRIVATE_KEY=

# --- GRVT (requires: go build -tags grvt) ---
EXCHANGES_GRVT_API_KEY=
EXCHANGES_GRVT_SUB_ACCOUNT_ID=
EXCHANGES_GRVT_PRIVATE_KEY=

# --- EdgeX (requires: go build -tags edgex) ---
EXCHANGES_EDGEX_PRIVATE_KEY=
EXCHANGES_EDGEX_ACCOUNT_ID=
