# =============================================================================
# Exchanges — Environment Variables for Integration Tests
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!

# --- Binance ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- OKX ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- Aster ---
ASTER_API_KEY=
ASTER_SECRET_KEY=

# --- Nado ---
NADO_PRIVATE_KEY=
NADO_SUBACCOUNT_NAME=

# --- Lighter ---
LIGHTER_PRIVATE_KEY=
LIGHTER_ACCOUNT_INDEX=
LIGHTER_KEY_INDEX=
LIGHTER_RO_TOKEN=

# --- Hyperliquid ---
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_VAULT=
HYPERLIQUID_ACCOUNT_ADDR=

# --- StandX ---
STANDX_PRIVATE_KEY=

# --- GRVT ---
GRVT_API_KEY=
GRVT_SUB_ACCOUNT_ID=
GRVT_PRIVATE_KEY=

# --- EdgeX ---
EDGEX_STARK_PRIVATE_KEY=
EDGEX_ACCOUNT_ID=

# --- Backpack ---
BACKPACK_API_KEY=
BACKPACK_PRIVATE_KEY=
BACKPACK_SPOT_TEST_SYMBOL=
BACKPACK_PERP_TEST_SYMBOL=
BACKPACK_QUOTE_CURRENCY=

# --- Decibel ---
DECIBEL_API_KEY=
DECIBEL_PRIVATE_KEY=
DECIBEL_SUBACCOUNT_ADDR=
DECIBEL_PERP_TEST_SYMBOL=

# --- Bitget ---
# Private Bitget integration tests use the classic account API surface only.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_SPOT_TEST_SYMBOL=
BITGET_PERP_TEST_SYMBOL=
BITGET_PERP_TEST_LEVERAGE=20
# Optional: set to 1 only when the API key has Bitget classic WS trade access enabled.
BITGET_ENABLE_WS_ORDER_TESTS=
BITGET_QUOTE_CURRENCY=
