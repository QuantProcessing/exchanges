# =============================================================================
# Exchanges — Environment Variables for Integration Tests
# =============================================================================
# Copy this file to .env and fill in your credentials.
# Test-specific symbols, quantities, prices, leverage, and live-write flags are
# intentionally not listed here; set them ad hoc only when running those tests.
# NEVER commit .env to version control!

# --- Binance ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_OPTION_API_KEY=
BINANCE_OPTION_SECRET_KEY=

# --- OKX ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- Aster ---
ASTER_API_KEY=
ASTER_SECRET_KEY=

# --- Nado ---
NADO_PRIVATE_KEY=
NADO_SUBACCOUNT_NAME=

# --- Lighter ---
LIGHTER_PRIVATE_KEY=
LIGHTER_ACCOUNT_INDEX=
LIGHTER_KEY_INDEX=
LIGHTER_RO_TOKEN=

# --- Hyperliquid ---
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_VAULT=
HYPERLIQUID_ACCOUNT_ADDR=

# --- StandX ---
STANDX_PRIVATE_KEY=

# --- GRVT ---
GRVT_API_KEY=
GRVT_SUB_ACCOUNT_ID=
GRVT_PRIVATE_KEY=

# --- EdgeX ---
EDGEX_STARK_PRIVATE_KEY=
EDGEX_ACCOUNT_ID=

# --- Backpack ---
BACKPACK_API_KEY=
BACKPACK_PRIVATE_KEY=

# --- Bitget ---
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
